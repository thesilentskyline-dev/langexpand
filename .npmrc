loglevel=error

strictStorePkgContentCheck=false
verifyStoreIntegrity=false

# 网络优化
network-concurrency=16
fetch-retries=3
fetch-timeout=60000

# 严格使用 peer dependencies
strict-peer-dependencies=false

# 自动生成 peer
auto-install-peers=true

# lockfile 配置
lockfile=true

# 不提示 npm 更新
update-notifier=false
