# ============================================================
# 运营视觉一键延展平台 - 环境变量配置
# ============================================================

# Google Gemini API 配置（必须）
# 获取方式：https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Google API 代理地址（可选）
# 如果所在网络无法直接访问 Google API，可配置中转代理
# GOOGLE_API_PROXY=https://your-proxy.example.com
